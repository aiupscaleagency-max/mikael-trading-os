# ═══════════════════════════════════════════════════════════════════════════
#  MIKAEL TRADING OS — KONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# ── Claude (Anthropic) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Läge ──
MODE=paper
LIVE_TRADING_CONFIRMED=false
EXECUTION_MODE=auto

# ── Vilka motorer ska köras (komma-separerat) ──
# Tillgängliga: politician_copy, wheel_strategy, crypto_momentum
ENGINES=crypto_momentum

# ════════════════════════════════════════════════════════════════════
#  BROKERS
# ════════════════════════════════════════════════════════════════════

# ── Alpaca (Aktier + Optioner) ──
# Paper: https://paper-api.alpaca.markets
# Live:  https://api.alpaca.markets
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Blofin (Krypto-derivat, leverage) ──
BLOFIN_API_KEY=
BLOFIN_API_SECRET=
BLOFIN_PASSPHRASE=
BLOFIN_BASE_URL=https://openapi.blofin.com

# ── Binance (Krypto spot, valfritt) ──
# Testnet: https://testnet.binance.vision
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_API_SECRET=

# ════════════════════════════════════════════════════════════════════
#  RISK-RAMAR + POSITION-SIZING (sätts av DIG)
# ════════════════════════════════════════════════════════════════════
# Hanna (Head Trader) defaultar till DEFAULT, anpassar mellan MIN och MAX
# baserat på conviction. Karin's vol-multiplier finjusterar.
DEFAULT_POSITION_USD=50
MIN_POSITION_USD=20
MAX_POSITION_USD=100
MAX_TOTAL_EXPOSURE_USD=500
MAX_DAILY_LOSS_USD=50
MAX_OPEN_POSITIONS=5

# ════════════════════════════════════════════════════════════════════
#  MOTOR C: CRYPTO MOMENTUM
# ════════════════════════════════════════════════════════════════════
# Top-15 likvida på Binance. Lägg till/ta bort efter behov.
CRYPTO_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,ADAUSDT,AVAXUSDT,DOGEUSDT,DOTUSDT,LINKUSDT,MATICUSDT,UNIUSDT,LTCUSDT,ATOMUSDT,NEARUSDT
CRYPTO_LEVERAGE=5
CRYPTO_TRAILING_STOP_PCT=2
CRYPTO_TP_STEPS=5,10,20

# ════════════════════════════════════════════════════════════════════
#  RESEARCH: PERPLEXITY (Lars)
# ════════════════════════════════════════════════════════════════════
# Lars körs först i varje session. Hämta nyckel: https://www.perplexity.ai/settings/api
# Pris: ~$0.005/anrop med Sonar Pro = $0.07/vecka.
PERPLEXITY_API_KEY=

# ════════════════════════════════════════════════════════════════════
#  FOREX: OANDA (för EUR/USD, GBP/USD osv)
# ════════════════════════════════════════════════════════════════════
# Skapa demo-konto: https://www.oanda.com/account/login
# Practice (demo): https://api-fxpractice.oanda.com
# Live:            https://api-fxtrade.oanda.com
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_BASE_URL=https://api-fxpractice.oanda.com
FOREX_SYMBOLS=EUR_USD,GBP_USD,USD_JPY,USD_CHF,AUD_USD,USD_CAD,EUR_GBP

# ════════════════════════════════════════════════════════════════════
#  MOTOR A: POLITICIAN COPY TRADING
# ════════════════════════════════════════════════════════════════════
STOCK_SYMBOLS=TSLA,NVDA,AAPL,MSFT

# ════════════════════════════════════════════════════════════════════
#  MOTOR B: WHEEL STRATEGY (Optioner)
# ════════════════════════════════════════════════════════════════════
WHEEL_UNDERLYINGS=TSLA,NVDA
# Delta ~0.3 = ~10% OTM, 70% sannolikhet att expira värdelös
WHEEL_PUT_DELTA=0.3
# Stäng kontraktet vid 50% vinst
WHEEL_PROFIT_TARGET_PCT=50

# ════════════════════════════════════════════════════════════════════
#  TIMING
# ════════════════════════════════════════════════════════════════════
# Agentens analysloop (sekunder). 300 = var 5:e minut.
LOOP_INTERVAL_SECONDS=300
# Position-scan för stop-loss-justering (sekunder). 900 = var 15:e min.
SCAN_INTERVAL_SECONDS=900
# Morning briefing-tid (UTC-timme). 7 = kl 09:00 svensk tid (CET).
BRIEFING_HOUR_UTC=7
